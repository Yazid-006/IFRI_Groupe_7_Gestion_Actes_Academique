<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.agent.DemandeController"
            prefWidth="1024" prefHeight="768"
            style="-fx-background-color: #f0f2f5;">

    <top>
        <VBox style="-fx-background-color: #1a2035; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <VBox spacing="2">
                    <Label text="GESTION DES DEMANDES" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label text="Traitement et suivi des demandes d'actes" textFill="#7986a8" style="-fx-font-size: 11px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleRetour" text="← Retour" style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0; -fx-font-size: 12px; -fx-padding: 7 16 7 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
            <HBox prefHeight="3" style="-fx-background-color: linear-gradient(to right, #3182ce, #805ad5, #e53e3e);"/>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent; -fx-padding: 24;">

            <Tab text="📋  Liste des demandes">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox spacing="20">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3">
                                <Label text="Demandes en cours" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                                <Label text="Consultez et traitez les demandes des usagers" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Filtrer :" style="-fx-font-size: 13px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="filtreStatutCombo" onAction="#handleFiltrerDemandes" prefWidth="160" style="-fx-background-radius: 6;"/>
                        </HBox>

                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">
                            <TableView fx:id="demandeTable" prefHeight="220" style="-fx-background-color: transparent;">
                                <placeholder>
                                    <Label text="Aucune demande trouvée." style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="numeroCol" text="N° Demande" prefWidth="140"/>
                                    <TableColumn fx:id="typeCol"   text="Type"       prefWidth="140"/>
                                    <TableColumn fx:id="usagerCol" text="Usager"     prefWidth="160"/>
                                    <TableColumn fx:id="dateCol"   text="Date"       prefWidth="160"/>
                                    <TableColumn fx:id="statutCol" text="Statut"     prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3); -fx-padding: 24;">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="📄" style="-fx-font-size: 16px;"/>
                                <Label text="Détails de la demande" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                            </HBox>
                            <Separator style="-fx-background-color: #edf2f7;"/>

                            <GridPane hgap="20" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints halignment="RIGHT" minWidth="110"/>
                                    <ColumnConstraints minWidth="200"/>
                                    <ColumnConstraints halignment="RIGHT" minWidth="110"/>
                                    <ColumnConstraints minWidth="200"/>
                                </columnConstraints>

                                <Label text="N° Demande :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="numeroDemandeLabel" style="-fx-font-weight: bold; -fx-text-fill: #1a2035;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Date :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <Label fx:id="dateDemandeLabel" style="-fx-text-fill: #2d3748;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Type d'acte :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="typeActeLabel" style="-fx-text-fill: #2d3748;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Statut :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <Label fx:id="statutLabel" style="-fx-text-fill: #2d3748;" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                <Label text="Usager :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label fx:id="usagerInfoLabel" wrapText="true" style="-fx-text-fill: #2d3748;" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="3"/>
                            </GridPane>

                            <VBox spacing="6">
                                <Label text="Motif de la demande :" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                                <TextArea fx:id="motifTextArea" editable="false" prefHeight="70" wrapText="true" style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Informations de traitement :" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                                <TextArea fx:id="traitementTextArea" editable="false" prefHeight="55" wrapText="true" style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px;"/>
                            </VBox>

                            <HBox spacing="12">
                                <Button fx:id="validerButton" onAction="#handleValiderDemande" text="✅ Valider" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 20 9 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                                <Button fx:id="rejeterButton" onAction="#handleRejeterDemande" text="❌ Rejeter" style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 20 9 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                                <Button fx:id="voirJustificatifsButton" onAction="#handleVoirJustificatifs" text="📎 Voir justificatifs" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 20 9 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab text="➕  Nouvelle demande">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox spacing="20">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <VBox spacing="3">
                            <Label text="Nouvelle demande" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                            <Label text="Créez une demande d'acte pour un usager" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                        </VBox>

                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3); -fx-padding: 20;">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="🔍" style="-fx-font-size: 14px;"/>
                                <Label text="Rechercher un usager" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                            </HBox>
                            <Separator style="-fx-background-color: #edf2f7;"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <TextField fx:id="rechercheUsagerField" onKeyReleased="#handleRechercherUsager" prefWidth="340" promptText="Nom, email ou n° usager" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #e2e8f0; -fx-padding: 9; -fx-font-size: 13px;"/>
                                <Button onAction="#handleRechercherUsager" text="Rechercher" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 9 20 9 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                            </HBox>
                            <TableView fx:id="usagerSearchTable" prefHeight="150" style="-fx-background-color: transparent;">
                                <placeholder>
                                    <Label text="Aucun usager trouvé." style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="usagerNumeroCol" text="N° Usager" prefWidth="140"/>
                                    <TableColumn fx:id="usagerNomCompletCol" text="Nom complet" prefWidth="220"/>
                                    <TableColumn fx:id="usagerEmailCol" text="Email" prefWidth="280"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3); -fx-padding: 20;">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="📝" style="-fx-font-size: 14px;"/>
                                <Label text="Informations de la demande" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                            </HBox>
                            <Separator style="-fx-background-color: #edf2f7;"/>

                            <GridPane hgap="20" vgap="14">
                                <columnConstraints>
                                    <ColumnConstraints halignment="RIGHT" minWidth="110"/>
                                    <ColumnConstraints minWidth="300"/>
                                </columnConstraints>
                                <Label text="Type d'acte :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="nouveauTypeCombo" prefWidth="300" style="-fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Motif :" style="-fx-text-fill: #4a5568; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextArea fx:id="nouveauMotifArea" prefHeight="100" wrapText="true" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #e2e8f0; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </GridPane>

                            <HBox>
                                <Button fx:id="enregistrerDemandeButton" disable="true" onAction="#handleEnregistrerDemande" text="💾 Enregistrer la demande" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
