<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.agent.AgentDashboardController"
            prefWidth="1024" prefHeight="768"
            style="-fx-background-color: #f0f2f5;">

    <!-- ═══ HEADER ═══ -->
    <top>
        <VBox style="-fx-background-color: #1a2035; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <padding>
                    <Insets top="14" right="24" bottom="14" left="24"/>
                </padding>
                <VBox spacing="2">
                    <Label text="ACTES ADMINISTRATIFS" textFill="white"
                           style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-letter-spacing: 1.5px;"/>
                    <Label text="Espace agent administratif" textFill="#7986a8"
                           style="-fx-font-size: 11px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="dateTimeLabel" text="..." textFill="#a0aec0"
                       style="-fx-font-size: 12px;"/>
                <Separator orientation="VERTICAL" style="-fx-background-color: #2d3748;" prefHeight="32"/>
                <HBox alignment="CENTER" spacing="12">
                    <Label fx:id="welcomeLabel" text="Agent" textFill="#e2e8f0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Button fx:id="deconnexionButton" onAction="#handleDeconnexion"
                            text="Déconnexion"
                            style="-fx-background-color: #e53e3e; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 7 16 7 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
            </HBox>
            <HBox prefHeight="3" style="-fx-background-color: linear-gradient(to right, #3182ce, #805ad5, #e53e3e);"/>
        </VBox>
    </top>

    <!-- ═══ SIDEBAR ═══ -->
    <left>
        <VBox prefWidth="220" style="-fx-background-color: #1e2a3a;">
            <padding>
                <Insets top="24" right="12" bottom="24" left="12"/>
            </padding>

            <Label text="NAVIGATION" textFill="#4a6080"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1.2px; -fx-padding: 0 0 8 8;"/>

            <Button fx:id="demandesButton" onAction="#handleDemandes"
                    prefWidth="196" text="📋  Gestion des demandes"
                    style="-fx-background-color: #2d3f54; -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px; -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <Button fx:id="actesButton" onAction="#handleActes"
                    prefWidth="196" text="📄  Gestion des actes"
                    style="-fx-background-color: #2d3f54; -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px; -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <Button fx:id="rechercheButton" onAction="#handleRecherche"
                    prefWidth="196" text="🔍  Recherche"
                    style="-fx-background-color: #2d3f54; -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px; -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="v1.0.0  •  Agent Panel" textFill="#2d4060"
                   style="-fx-font-size: 10px; -fx-padding: 8;"/>
        </VBox>
    </left>

    <!-- ═══ CONTENU PRINCIPAL ═══ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="28" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <!-- Titre -->
                <VBox spacing="4">
                    <Label text="Tableau de bord"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    <Label text="Vue d'ensemble de votre activité"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                </VBox>

                <!-- KPI Cards -->
                <HBox spacing="20">
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="⏳" style="-fx-font-size: 22px;"/>
                            <Label text="Demandes en attente"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="demandesEnAttenteLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="À traiter" style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <HBox prefHeight="4" style="-fx-background-color: #e67e22; -fx-background-radius: 2;"/>
                    </VBox>

                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="✅" style="-fx-font-size: 22px;"/>
                            <Label text="Demandes traitées"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="demandesTraiteesLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Validées et rejetées" style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <HBox prefHeight="4" style="-fx-background-color: #27ae60; -fx-background-radius: 2;"/>
                    </VBox>

                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="📄" style="-fx-font-size: 22px;"/>
                            <Label text="Actes émis"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="actesEmisLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Actes générés" style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <HBox prefHeight="4" style="-fx-background-color: #3182ce; -fx-background-radius: 2;"/>
                    </VBox>
                </HBox>

                <!-- Aide contextuelle -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: #ebf8ff; -fx-background-radius: 10;
                             -fx-border-color: #bee3f8; -fx-border-radius: 10; -fx-padding: 16;">
                    <Label text="ℹ️" style="-fx-font-size: 16px;"/>
                    <Label text="Sélectionnez une option dans le menu de gauche pour accéder aux fonctionnalités."
                           style="-fx-font-size: 13px; -fx-text-fill: #2b6cb0;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
