<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.admin.ConfigurationController"
            prefWidth="1024" prefHeight="768"
            style="-fx-background-color: #f0f2f5;">

    <!-- ═══ HEADER ═══ -->
    <top>
        <VBox style="-fx-background-color: #1a2035; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <padding>
                    <Insets top="14" right="24" bottom="14" left="24"/>
                </padding>
                <VBox spacing="2">
                    <Label text="CONFIGURATION" textFill="white"
                           style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label text="Paramètres généraux du système" textFill="#7986a8"
                           style="-fx-font-size: 11px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleRetour" text="← Retour"
                        style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0;
                               -fx-font-size: 12px; -fx-padding: 7 16 7 16;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
            <HBox prefHeight="3" style="-fx-background-color: linear-gradient(to right, #3182ce, #805ad5, #e53e3e);"/>
        </VBox>
    </top>

    <!-- ═══ CONTENU ═══ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <VBox spacing="3">
                    <Label text="Paramètres généraux"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    <Label text="Ces informations apparaîtront sur les actes générés"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                </VBox>

                <!-- ─── Section Établissement ─── -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                             -fx-padding: 24;">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🏛️" style="-fx-font-size: 16px;"/>
                        <Label text="Informations de l'établissement"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #edf2f7;"/>

                    <GridPane hgap="20" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints minWidth="180" halignment="RIGHT"/>
                            <ColumnConstraints minWidth="300"/>
                        </columnConstraints>

                        <Label text="Nom de l'établissement :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="nomEtablissementField"
                                   promptText="Ex: IFRI"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #e2e8f0; -fx-padding: 9;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Adresse :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="adresseField"
                                   promptText="Ex: Cotonou, Bénin"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #e2e8f0; -fx-padding: 9;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Année académique :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="anneeAcademiqueField"
                                   promptText="Ex: 2024-2025"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #e2e8f0; -fx-padding: 9;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>

                <!-- ─── Section Demandes ─── -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                             -fx-padding: 24;">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📋" style="-fx-font-size: 16px;"/>
                        <Label text="Paramètres des demandes"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #edf2f7;"/>

                    <GridPane hgap="20" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints minWidth="180" halignment="RIGHT"/>
                            <ColumnConstraints minWidth="300"/>
                        </columnConstraints>

                        <Label text="Préfixe numéro demande :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <TextField fx:id="prefixeDemandeField"
                                       promptText="Ex: IFRI"
                                       style="-fx-background-radius: 6; -fx-border-radius: 6;
                                              -fx-border-color: #e2e8f0; -fx-padding: 9;"/>
                            <Label text="Le numéro généré sera : IFRI-2025-0001"
                                   style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        </VBox>

                        <Label text="Délai de traitement (jours) :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <TextField fx:id="delaiTraitementField"
                                       promptText="Ex: 5"
                                       style="-fx-background-radius: 6; -fx-border-radius: 6;
                                              -fx-border-color: #e2e8f0; -fx-padding: 9;"/>
                            <Label text="Nombre de jours avant qu'une demande soit considérée en retard"
                                   style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- ─── Section Signataire ─── -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                             -fx-padding: 24;">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✍️" style="-fx-font-size: 16px;"/>
                        <Label text="Informations du signataire"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #edf2f7;"/>

                    <GridPane hgap="20" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints minWidth="180" halignment="RIGHT"/>
                            <ColumnConstraints minWidth="300"/>
                        </columnConstraints>

                        <Label text="Nom du signataire :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="nomSignataireField"
                                   promptText="Ex: Dr. Jean KOUASSI"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #e2e8f0; -fx-padding: 9;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Fonction du signataire :"
                               style="-fx-text-fill: #4a5568; -fx-font-weight: bold;"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="fonctionSignataireField"
                                   promptText="Ex: Directeur de l'IFRI"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #e2e8f0; -fx-padding: 9;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>

                <!-- ─── Bouton Sauvegarder ─── -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#handleAnnuler" text="Annuler"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-padding: 10 24 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button onAction="#handleSauvegarder" text="💾  Sauvegarder"
                            style="-fx-background-color: #3182ce; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-padding: 10 24 10 24; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
