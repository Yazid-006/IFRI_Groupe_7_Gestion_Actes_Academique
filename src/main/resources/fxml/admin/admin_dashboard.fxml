<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controller.admin.AdminDashboardController"
        prefWidth="1024"
        prefHeight="768"
        style="-fx-background-color: #f0f2f5;">

    <!-- ═══════════════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #1a2035; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 0, 2);">

            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #1a2035;">
                <padding>
                    <Insets top="14" right="24" bottom="14" left="24"/>
                </padding>

                <!-- Logo / Titre -->
                <VBox spacing="2">
                    <Label text="ACTES ADMINISTRATIFS"
                           textFill="white"
                           style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-letter-spacing: 1.5px;"/>
                    <Label text="Système de gestion"
                           textFill="#7986a8"
                           style="-fx-font-size: 11px;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Heure -->
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="dateTimeLabel" text="Chargement..."
                           textFill="#a0aec0"
                           style="-fx-font-size: 12px;"/>
                </VBox>

                <!-- Séparateur vertical -->
                <Separator orientation="VERTICAL" style="-fx-background-color: #2d3748;" prefHeight="32"/>

                <!-- Profil + Déconnexion -->
                <HBox alignment="CENTER" spacing="12">
                    <Label fx:id="welcomeLabel" text="Admin"
                           textFill="#e2e8f0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Button fx:id="deconnexionButton"
                            onAction="#handleDeconnexion"
                            text="Déconnexion"
                            style="-fx-background-color: #e53e3e;
                                   -fx-text-fill: white;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 7 16 7 16;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>
                </HBox>
            </HBox>

            <!-- Barre de progression decorative -->
            <HBox prefHeight="3" style="-fx-background-color: linear-gradient(to right, #3182ce, #805ad5, #e53e3e);"/>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════
         SIDEBAR GAUCHE
    ═══════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="220" style="-fx-background-color: #1e2a3a;">
            <padding>
                <Insets top="24" right="12" bottom="24" left="12"/>
            </padding>

            <!-- Section label -->
            <Label text="NAVIGATION"
                   textFill="#4a6080"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1.2px; -fx-padding: 0 0 8 8;"/>

            <!-- Bouton Utilisateurs -->
            <Button fx:id="utilisateursButton"
                    onAction="#handleUtilisateurs"
                    prefWidth="196"
                    text="👥  Gestion Utilisateurs"
                    style="-fx-background-color: #2d3f54;
                           -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px;
                           -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;"/>
            <VBox.margin>
                <Insets top="4"/>
            </VBox.margin>

            <!-- Bouton Rapports -->
            <Button fx:id="rapportsButton"
                    onAction="#handleRapports"
                    prefWidth="196"
                    text="📊  Statistiques &amp; Rapports"
                    style="-fx-background-color: #2d3f54;
                           -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px;
                           -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin>
                    <Insets top="4"/>
                </VBox.margin>
            </Button>

            <!-- Bouton Configuration -->
            <Button fx:id="configButton"
                    onAction="#handleConfiguration"
                    prefWidth="196"
                    text="⚙️  Configuration"
                    style="-fx-background-color: #2d3f54;
                           -fx-text-fill: #c8d6e8;
                           -fx-font-size: 13px;
                           -fx-padding: 12 16 12 16;
                           -fx-background-radius: 8;
                           -fx-alignment: CENTER_LEFT;
                           -fx-cursor: hand;">
                <VBox.margin>
                    <Insets top="4"/>
                </VBox.margin>
            </Button>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Version info -->
            <Label text="v1.0.0  •  Admin Panel"
                   textFill="#2d4060"
                   style="-fx-font-size: 10px; -fx-padding: 8;"/>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════
         CONTENU PRINCIPAL
    ═══════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="28" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <!-- Titre de section -->
                <VBox spacing="4">
                    <Label text="Tableau de bord"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                    <Label text="Vue d'ensemble de l'activité du système"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                </VBox>

                <!-- ─── Ligne de KPI Cards ─── -->
                <HBox spacing="20">

                    <!-- Card : Total Demandes -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="📋" style="-fx-font-size: 22px;"/>
                            <Label text="Total des demandes"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="totalDemandesLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Toutes périodes confondues"
                               style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <!-- Barre couleur en bas -->
                        <HBox prefHeight="4" style="-fx-background-color: #3182ce; -fx-background-radius: 2;"/>
                    </VBox>

                    <!-- Card : En attente -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="⏳" style="-fx-font-size: 22px;"/>
                            <Label text="Demandes en attente"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="demandesEnAttenteLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Nécessitent une action"
                               style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <HBox prefHeight="4" style="-fx-background-color: #e67e22; -fx-background-radius: 2;"/>
                    </VBox>

                    <!-- Card : Total Actes -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);
                                 -fx-padding: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="✅" style="-fx-font-size: 22px;"/>
                            <Label text="Total des actes émis"
                                   style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="totalActesLabel" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Actes validés et archivés"
                               style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                        <HBox prefHeight="4" style="-fx-background-color: #27ae60; -fx-background-radius: 2;"/>
                    </VBox>

                </HBox>

                <!-- ─── Section Activité récente (placeholder) ─── -->
                <VBox spacing="16"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);
                             -fx-padding: 24;">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Activité récente"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2035;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Voir tout →"
                               style="-fx-font-size: 12px; -fx-text-fill: #3182ce; -fx-cursor: hand;"/>
                    </HBox>

                    <Separator style="-fx-background-color: #edf2f7;"/>

                    <TableView fx:id="activiteTable" prefHeight="220">

                        <placeholder>
                            <Label text="Aucune activité récente à afficher."
                                   style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>
                        </placeholder>

                        <columns>
                            <TableColumn fx:id="colNumeroDemande" text="N° Demande"  prefWidth="120" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="colTypeActe"      text="Type"        prefWidth="140" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="colDemandeur"     text="Demandeur"   prefWidth="160" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="colStatut"        text="Statut"      prefWidth="110" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="colDate"          text="Date"        prefWidth="130" style="-fx-text-fill: black; -fx-font-weight: bold;"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- ─── Aide contextuelle ─── -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: #ebf8ff;
                             -fx-background-radius: 10;
                             -fx-border-color: #bee3f8;
                             -fx-border-radius: 10;
                             -fx-padding: 16;">
                    <Label text="ℹ️" style="-fx-font-size: 16px;"/>
                    <Label text="Sélectionnez une option dans le menu de gauche pour accéder aux fonctionnalités."
                           style="-fx-font-size: 13px; -fx-text-fill: #2b6cb0;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
