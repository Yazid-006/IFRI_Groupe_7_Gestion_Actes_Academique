<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label text="GESTION DES ACTES ADMINISTRATIFS" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="18" />
        </font>
    </Label>

    <Label text="IFRI - Groupe 7" textFill="#7f8c8d">
        <font>
            <Font size="14" />
        </font>
    </Label>

    <Separator prefWidth="300" />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="80" />
            <ColumnConstraints minWidth="200" />
        </columnConstraints>

        <Label text="Email :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="emailField" promptText="Entrez votre email" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Mot de passe :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label fx:id="errorLabel" style="-fx-text-fill: red;" text="Email ou mot de passe incorrect" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="2" />
    </GridPane>

    <Button fx:id="loginButton" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Se connecter">
        <font>
            <Font size="14" />
        </font>
    </Button>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Comptes de test :" />
        <Label text="admin@ifri.bj / admin" style="-fx-text-fill: #27ae60;" />
        <Label text="|" />
        <Label text="agent@ifri.bj / agent123" style="-fx-text-fill: #e67e22;" />
        <Label text="|" />
        <Label text="usager@ifri.bj / Aucun" style="-fx-text-fill: #8e44ad;" />
    </HBox>
</VBox>